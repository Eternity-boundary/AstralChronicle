<Page
    x:Class="AstralChronicle.FeaturePlaceholderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Style="{StaticResource AstralPageScrollViewerStyle}">
        <StackPanel MaxWidth="{StaticResource AstralFeatureContentMaxWidth}" Spacing="{StaticResource AstralSectionSpacing}">
            <TextBlock
                AutomationProperties.AutomationId="FeaturePlaceholderHeading"
                Style="{StaticResource AstralPageTitleTextBlockStyle}"
                Text="{x:Bind ViewModel.Heading, Mode=OneWay}" />
            <TextBlock
                AutomationProperties.AutomationId="FeaturePlaceholderDescription"
                Style="{StaticResource AstralBodyTextBlockStyle}"
                Text="{x:Bind ViewModel.Description, Mode=OneWay}"
                TextWrapping="Wrap" />
            <InfoBar
                x:Uid="LazyFeatureInfoBar"
                IsClosable="False"
                IsOpen="True"
                Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>
