<?xml version="1.0" encoding="utf-8" ?>
<!--  Created by EternityBoundary on Jul 20,2026  -->
<Page
    x:Class="AstralChronicle.EventLogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AstralChronicle">

    <Grid
        x:Name="PageRoot"
        RowSpacing="{StaticResource AstralContentSpacing}"
        Style="{StaticResource AstralPageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="{StaticResource AstralContentSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                <TextBlock
                    AutomationProperties.AutomationId="EventLogsHeading"
                    Style="{StaticResource AstralPageTitleTextBlockStyle}"
                    Text="{x:Bind ViewModel.Heading, Mode=OneWay}" />
                <StackPanel Orientation="Horizontal" Spacing="{StaticResource AstralContentSpacing}">
                    <TextBlock
                        x:Uid="EventLogsChannelLabel"
                        Style="{StaticResource AstralCaptionTextBlockStyle}" />
                    <TextBlock
                        AutomationProperties.AutomationId="EventLogsChannelPath"
                        Style="{StaticResource AstralCaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.ChannelPath, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </StackPanel>
            <AutoSuggestBox
                x:Uid="EventLogsSearchBox"
                Grid.Column="1"
                Width="260"
                VerticalAlignment="Center"
                AutomationProperties.AutomationId="EventLogsSearchBox"
                IsEnabled="True"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <AutoSuggestBox.QueryIcon>
                    <SymbolIcon Symbol="Find" />
                </AutoSuggestBox.QueryIcon>
            </AutoSuggestBox>
            <CommandBar
                Grid.Column="2"
                AutomationProperties.AutomationId="EventLogsCommandBar"
                Background="{ThemeResource AstralTransparentBrush}"
                DefaultLabelPosition="Right"
                IsOpen="True"
                VerticalAlignment="Center">
                <AppBarButton
                    x:Uid="EventLogsRefreshCommand"
                    AutomationProperties.AutomationId="EventLogsRefreshCommand"
                    Click="OnRefreshClicked">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Refresh" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton
                    x:Name="FilterCommand"
                    x:Uid="EventLogsFilterCommand"
                    AutomationProperties.AutomationId="EventLogsFilterCommand">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Filter" />
                    </AppBarButton.Icon>
                    <AppBarButton.Flyout>
                        <Flyout x:Name="FilterFlyout" Placement="Bottom">
                            <ScrollViewer MaxHeight="560">
                                <StackPanel Width="360" Spacing="{StaticResource AstralContentSpacing}">
                                    <TextBlock
                                        x:Uid="EventLogsFilterFlyoutTitle"
                                        Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                                    <TextBox
                                        x:Uid="EventLogsFilterProviderBox"
                                        AutomationProperties.AutomationId="EventLogsFilterProviderBox"
                                        Text="{x:Bind ViewModel.FilterProvider, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox
                                        x:Uid="EventLogsFilterEventIdBox"
                                        AutomationProperties.AutomationId="EventLogsFilterEventIdBox"
                                        InputScope="Number"
                                        Text="{x:Bind ViewModel.FilterEventId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox
                                        x:Uid="EventLogsFilterLevelBox"
                                        AutomationProperties.AutomationId="EventLogsFilterLevelBox"
                                        SelectedValue="{x:Bind ViewModel.FilterLevel, Mode=OneWay}"
                                        SelectedValuePath="Tag"
                                        SelectionChanged="OnFilterLevelChanged">
                                        <ComboBoxItem x:Uid="EventLogsFilterLevelAny" Tag="Any" />
                                        <ComboBoxItem x:Uid="EventLogsFilterLevelCritical" Tag="Critical" />
                                        <ComboBoxItem x:Uid="EventLogsFilterLevelError" Tag="Error" />
                                        <ComboBoxItem x:Uid="EventLogsFilterLevelWarning" Tag="Warning" />
                                        <ComboBoxItem x:Uid="EventLogsFilterLevelInformation" Tag="Information" />
                                    </ComboBox>
                                    <TextBox
                                        x:Uid="EventLogsFilterTaskBox"
                                        AutomationProperties.AutomationId="EventLogsFilterTaskBox"
                                        InputScope="Number"
                                        Text="{x:Bind ViewModel.FilterTask, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox
                                        x:Uid="EventLogsFilterOpcodeBox"
                                        AutomationProperties.AutomationId="EventLogsFilterOpcodeBox"
                                        InputScope="Number"
                                        Text="{x:Bind ViewModel.FilterOpcode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox
                                        x:Uid="EventLogsFilterKeywordBox"
                                        AutomationProperties.AutomationId="EventLogsFilterKeywordBox"
                                        InputScope="Number"
                                        Text="{x:Bind ViewModel.FilterKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox
                                        x:Uid="EventLogsFilterProcessIdBox"
                                        AutomationProperties.AutomationId="EventLogsFilterProcessIdBox"
                                        InputScope="Number"
                                        Text="{x:Bind ViewModel.FilterProcessId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox
                                        x:Uid="EventLogsFilterThreadIdBox"
                                        AutomationProperties.AutomationId="EventLogsFilterThreadIdBox"
                                        InputScope="Number"
                                        Text="{x:Bind ViewModel.FilterThreadId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox
                                        x:Uid="EventLogsFilterUserBox"
                                        AutomationProperties.AutomationId="EventLogsFilterUserBox"
                                        Text="{x:Bind ViewModel.FilterUser, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox
                                        x:Uid="EventLogsFilterComputerBox"
                                        AutomationProperties.AutomationId="EventLogsFilterComputerBox"
                                        Text="{x:Bind ViewModel.FilterComputer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ToggleSwitch
                                        x:Uid="EventLogsFilterAfterToday"
                                        AutomationProperties.AutomationId="EventLogsFilterAfterToday"
                                        IsOn="{x:Bind ViewModel.FilterAfterToday, Mode=TwoWay}" />
                                    <TextBox
                                        x:Uid="EventLogsFilterAfterHoursBox"
                                        AutomationProperties.AutomationId="EventLogsFilterAfterHoursBox"
                                        InputScope="Number"
                                        Text="{x:Bind ViewModel.FilterAfterHours, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox
                                        x:Uid="EventLogsRawXPathBox"
                                        AutomationProperties.AutomationId="EventLogsRawXPathBox"
                                        AcceptsReturn="True"
                                        MaxHeight="120"
                                        Text="{x:Bind ViewModel.RawXPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AstralContentSpacing}">
                                        <Button
                                            x:Uid="EventLogsApplyFilterButton"
                                            AutomationProperties.AutomationId="EventLogsApplyFilterButton"
                                            Click="OnApplyStructuredFilterClicked" />
                                        <Button
                                            x:Uid="EventLogsClearStructuredFilterButton"
                                            AutomationProperties.AutomationId="EventLogsClearStructuredFilterButton"
                                            Click="OnClearStructuredFilterClicked" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Flyout>
                    </AppBarButton.Flyout>
                </AppBarButton>
                <AppBarButton
                    x:Uid="EventLogsClearFilterCommand"
                    AutomationProperties.AutomationId="EventLogsClearFilterCommand"
                    Click="OnClearFilterClicked"
                    IsEnabled="{x:Bind ViewModel.HasFilter, Mode=OneWay}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Clear" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton
                    x:Uid="EventLogsCopyCommand"
                    AutomationProperties.AutomationId="EventLogsCopyCommand"
                    Click="OnCopyClicked"
                    IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Copy" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton
                    x:Uid="EventLogsBookmarkCommand"
                    AutomationProperties.AutomationId="EventLogsBookmarkCommand"
                    Click="OnBookmarkClicked"
                    IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Favorite" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton
                    x:Uid="EventLogsExportCommand"
                    AutomationProperties.AutomationId="EventLogsExportCommand"
                    Click="OnExportClicked"
                    IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Save" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton
                    x:Uid="EventLogsToggleDetailsCommand"
                    AutomationProperties.AutomationId="EventLogsToggleDetailsCommand"
                    Click="OnToggleDetailsClicked">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="View" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <CommandBar.SecondaryCommands>
                    <AppBarButton x:Uid="EventLogsFindNextCommand" IsEnabled="False">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Find" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Uid="EventLogsFindPreviousCommand" IsEnabled="False">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Find" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton x:Uid="EventLogsSaveViewCommand" IsEnabled="False">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Save" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Uid="EventLogsOpenSavedLogCommand" IsEnabled="False">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="OpenFile" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Uid="EventLogsClearLogCommand" IsEnabled="False">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Delete" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Uid="EventLogsPropertiesCommand" IsEnabled="False">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Setting" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Uid="EventLogsLiveUpdatesCommand" IsEnabled="False">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Play" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Uid="EventLogsHelpCommand" IsEnabled="False">
                        <AppBarButton.Icon>
                            <SymbolIcon Symbol="Help" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar.SecondaryCommands>
            </CommandBar>
        </Grid>

        <InfoBar
            x:Uid="EventLogsStatusInfoBar"
            Grid.Row="1"
            AutomationProperties.AutomationId="EventLogsStatusInfoBar"
            IsClosable="False"
            IsOpen="{x:Bind ViewModel.HasStatusMessage, Mode=OneWay}"
            Message="{x:Bind ViewModel.StatusDetails, Mode=OneWay}"
            Severity="{x:Bind ViewModel.StatusSeverity, Mode=OneWay}"
            Title="{x:Bind ViewModel.StatusText, Mode=OneWay}" />

        <TextBlock
            Grid.Row="2"
            AutomationProperties.AutomationId="EventLogsFilterSummary"
            Style="{StaticResource AstralCaptionTextBlockStyle}"
            Text="{x:Bind ViewModel.FilterSummary, Mode=OneWay}" />

        <Grid
            x:Name="ContentGrid"
            Grid.Row="3"
            ColumnSpacing="{StaticResource AstralContentSpacing}"
            SizeChanged="OnContentGridSizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="0" />
            </Grid.RowDefinitions>

            <Border
                x:Name="ChannelPane"
                Grid.Column="0"
                Grid.Row="0"
                AutomationProperties.AutomationId="EventLogsChannelPane"
                Style="{StaticResource AstralCardBorderStyle}">
                <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                    <TextBlock
                        x:Uid="EventLogsChannelPaneTitle"
                        Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                    <TextBlock
                        x:Uid="EventLogsChannelPaneDescription"
                        Style="{StaticResource AstralCaptionTextBlockStyle}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        AutomationProperties.AutomationId="EventLogsCurrentChannel"
                        Style="{StaticResource AstralBodyTextBlockStyle}"
                        Text="{x:Bind ViewModel.ChannelPath, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Grid
                x:Name="EventListPane"
                Grid.Column="1"
                Grid.Row="0"
                RowSpacing="{StaticResource AstralContentSpacing}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid
                    Grid.Row="0"
                    ColumnSpacing="{StaticResource AstralContentSpacing}"
                    MinHeight="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <HyperlinkButton x:Uid="EventLogsLevelHeaderButton" Tag="Level" Click="OnSortClicked" Grid.Column="0" Style="{StaticResource DefaultHyperlinkButtonStyle}" />
                    <HyperlinkButton x:Uid="EventLogsTimeHeaderButton" Tag="Time" Click="OnSortClicked" Grid.Column="1" Style="{StaticResource DefaultHyperlinkButtonStyle}" />
                    <HyperlinkButton x:Uid="EventLogsProviderHeaderButton" Tag="Provider" Click="OnSortClicked" Grid.Column="2" Style="{StaticResource DefaultHyperlinkButtonStyle}" />
                    <HyperlinkButton x:Uid="EventLogsIdHeaderButton" Tag="EventId" Click="OnSortClicked" Grid.Column="3" Style="{StaticResource DefaultHyperlinkButtonStyle}" />
                    <HyperlinkButton x:Uid="EventLogsTaskHeaderButton" Tag="Task" Click="OnSortClicked" Grid.Column="4" Style="{StaticResource DefaultHyperlinkButtonStyle}" />
                    <HyperlinkButton x:Uid="EventLogsChannelHeaderButton" Tag="Channel" Click="OnSortClicked" Grid.Column="5" Style="{StaticResource DefaultHyperlinkButtonStyle}" />
                    <HyperlinkButton x:Uid="EventLogsUserHeaderButton" Tag="User" Click="OnSortClicked" Grid.Column="6" Style="{StaticResource DefaultHyperlinkButtonStyle}" />
                    <HyperlinkButton x:Uid="EventLogsComputerHeaderButton" Tag="Computer" Click="OnSortClicked" Grid.Column="7" Style="{StaticResource DefaultHyperlinkButtonStyle}" />
                    <HyperlinkButton x:Uid="EventLogsDescriptionHeaderButton" Tag="Description" Click="OnSortClicked" Grid.Column="8" Style="{StaticResource DefaultHyperlinkButtonStyle}" />
                </Grid>
                <ListView
                    x:Name="EventList"
                    Grid.Row="1"
                    AutomationProperties.AutomationId="EventLogsEventList"
                    IsItemClickEnabled="False"
                    ItemsSource="{x:Bind ViewModel.Events, Mode=OneWay}"
                    SelectionChanged="OnSelectionChanged"
                    SelectedItem="{x:Bind ViewModel.SelectedEvent, Mode=TwoWay}"
                    SelectionMode="Multiple"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ShowsScrollingPlaceholders="True">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:EventLogItemViewModel">
                            <Grid ColumnSpacing="{StaticResource AstralContentSpacing}" MinHeight="40">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            x:Uid="EventLogsCopyMenuItem"
                                            Click="OnCopyClicked" />
                                        <MenuFlyoutItem
                                            x:Uid="EventLogsBookmarkMenuItem"
                                            Click="OnBookmarkClicked" />
                                        <MenuFlyoutItem
                                            x:Uid="EventLogsExportMenuItem"
                                            Click="OnExportClicked" />
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="84" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Style="{StaticResource AstralBodyTextBlockStyle}"
                                    Text="{x:Bind Level, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="1"
                                    Style="{StaticResource AstralCaptionTextBlockStyle}"
                                    Text="{x:Bind TimeCreated, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="2"
                                    Style="{StaticResource AstralBodyTextBlockStyle}"
                                    Text="{x:Bind Provider, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="3"
                                    Style="{StaticResource AstralBodyTextBlockStyle}"
                                    Text="{x:Bind EventId, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="4"
                                    Style="{StaticResource AstralCaptionTextBlockStyle}"
                                    Text="{x:Bind TaskCategory, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="5"
                                    Style="{StaticResource AstralCaptionTextBlockStyle}"
                                    Text="{x:Bind Channel, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="6"
                                    Style="{StaticResource AstralCaptionTextBlockStyle}"
                                    Text="{x:Bind User, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="7"
                                    Style="{StaticResource AstralCaptionTextBlockStyle}"
                                    Text="{x:Bind Computer, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="8"
                                    Style="{StaticResource AstralCaptionTextBlockStyle}"
                                    Text="{x:Bind ShortDescription, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Border
                x:Name="DetailsPane"
                Grid.Column="2"
                Grid.Row="0"
                AutomationProperties.AutomationId="EventLogsDetailsPane"
                Style="{StaticResource AstralCardBorderStyle}">
                <TabView IsAddTabButtonVisible="False">
                    <TabViewItem x:Uid="EventLogsSummaryTab">
                        <Grid RowSpacing="{StaticResource AstralContentSpacing}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="EventLogsSelectedEventTitle"
                                Grid.Row="0"
                                Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                            <ScrollViewer Grid.Row="1">
                                <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                                    <TextBlock x:Uid="EventLogsProviderLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedProvider" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedProvider, Mode=OneWay}" TextWrapping="Wrap" />
                                    <TextBlock x:Uid="EventLogsEventIdLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedEventId" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedEventId, Mode=OneWay}" />
                                    <TextBlock x:Uid="EventLogsVersionLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedVersion" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedVersion, Mode=OneWay}" />
                                    <TextBlock x:Uid="EventLogsLevelLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedLevel" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedLevel, Mode=OneWay}" />
                                    <TextBlock x:Uid="EventLogsOpcodeLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedOpcode" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedOpcode, Mode=OneWay}" />
                                    <TextBlock x:Uid="EventLogsKeywordsLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedKeywords" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedKeywords, Mode=OneWay}" />
                                    <TextBlock x:Uid="EventLogsTimeLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedTime" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedTimeCreated, Mode=OneWay}" />
                                    <TextBlock x:Uid="EventLogsTaskCategoryLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedTask" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedTaskCategory, Mode=OneWay}" />
                                    <TextBlock x:Uid="EventLogsChannelDetailLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedChannel" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedChannel, Mode=OneWay}" TextWrapping="Wrap" />
                                    <TextBlock x:Uid="EventLogsComputerLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedComputer" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedComputer, Mode=OneWay}" TextWrapping="Wrap" />
                                    <TextBlock x:Uid="EventLogsRecordIdLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedRecordId" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedRecordId, Mode=OneWay}" />
                                    <TextBlock x:Uid="EventLogsProcessIdLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedProcessId" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedProcessId, Mode=OneWay}" />
                                    <TextBlock x:Uid="EventLogsThreadIdLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedThreadId" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedThreadId, Mode=OneWay}" />
                                    <TextBlock x:Uid="EventLogsActivityIdLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedActivityId" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedActivityId, Mode=OneWay}" TextWrapping="Wrap" />
                                    <TextBlock x:Uid="EventLogsRelatedActivityIdLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedRelatedActivityId" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedRelatedActivityId, Mode=OneWay}" TextWrapping="Wrap" />
                                    <TextBlock x:Uid="EventLogsDescriptionLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                                    <TextBlock AutomationProperties.AutomationId="EventLogsSelectedDescription" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedDescription, Mode=OneWay}" TextWrapping="Wrap" />
                                    <TextBlock
                                        AutomationProperties.AutomationId="EventLogsDetailsStatus"
                                        Style="{StaticResource AstralCaptionTextBlockStyle}"
                                        Text="{x:Bind ViewModel.DetailsStatusText, Mode=OneWay}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabViewItem>
                    <TabViewItem x:Uid="EventLogsDetailsTab">
                        <ScrollViewer>
                            <TextBlock
                                AutomationProperties.AutomationId="EventLogsSelectedMessage"
                                Style="{StaticResource AstralBodyTextBlockStyle}"
                                Text="{x:Bind ViewModel.SelectedMessage, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </TabViewItem>
                    <TabViewItem x:Uid="EventLogsEventDataTab">
                        <ScrollViewer>
                            <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                                <TextBlock AutomationProperties.AutomationId="EventLogsSelectedEventData" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedEventData, Mode=OneWay}" TextWrapping="Wrap" />
                                <TextBlock AutomationProperties.AutomationId="EventLogsSelectedUserData" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.SelectedUserData, Mode=OneWay}" TextWrapping="Wrap" />
                                <TextBlock AutomationProperties.AutomationId="EventLogsSelectedProviderMetadata" Style="{StaticResource AstralCaptionTextBlockStyle}" Text="{x:Bind ViewModel.SelectedProviderMetadata, Mode=OneWay}" TextWrapping="Wrap" />
                                <TextBlock AutomationProperties.AutomationId="EventLogsSelectedBinaryData" Style="{StaticResource AstralCaptionTextBlockStyle}" Text="{x:Bind ViewModel.SelectedBinaryData, Mode=OneWay}" TextWrapping="Wrap" />
                                <TextBlock AutomationProperties.AutomationId="EventLogsSelectedRelatedEvents" Style="{StaticResource AstralCaptionTextBlockStyle}" Text="{x:Bind ViewModel.SelectedRelatedEvents, Mode=OneWay}" TextWrapping="Wrap" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>
                    <TabViewItem x:Uid="EventLogsXmlTab">
                        <ScrollViewer>
                            <TextBlock
                                AutomationProperties.AutomationId="EventLogsSelectedXml"
                                Style="{StaticResource AstralBodyTextBlockStyle}"
                                Text="{x:Bind ViewModel.SelectedXml, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </TabViewItem>
                </TabView>
            </Border>
        </Grid>
    </Grid>
</Page>
