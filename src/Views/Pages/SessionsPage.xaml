<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="AstralChronicle.SessionsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="PageRoot" RowSpacing="{StaticResource AstralContentSpacing}" Style="{StaticResource AstralPageGridStyle}">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <Grid ColumnSpacing="{StaticResource AstralContentSpacing}"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel Spacing="{StaticResource AstralContentSpacing}"><TextBlock x:Uid="SessionsHeading" AutomationProperties.AutomationId="SessionsHeading" Style="{StaticResource AstralPageTitleTextBlockStyle}" /><TextBlock AutomationProperties.AutomationId="SessionsSummary" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.Summary, Mode=OneWay}" TextWrapping="Wrap" /></StackPanel><CommandBar Grid.Column="1" x:Name="SessionsCommandBar" DefaultLabelPosition="Right"><AppBarButton x:Uid="SessionsNewCommand" Click="OnNewClicked"><AppBarButton.Icon><SymbolIcon Symbol="Add" /></AppBarButton.Icon></AppBarButton><AppBarButton x:Uid="SessionsSaveCommand" Click="OnSaveClicked" IsEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}"><AppBarButton.Icon><SymbolIcon Symbol="Save" /></AppBarButton.Icon></AppBarButton><AppBarButton x:Uid="SessionsResumeCommand" Click="OnResumeClicked" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"><AppBarButton.Icon><SymbolIcon Symbol="Play" /></AppBarButton.Icon></AppBarButton><AppBarButton x:Uid="SessionsPinCommand" Click="OnPinClicked" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"><AppBarButton.Icon><SymbolIcon Symbol="Favorite" /></AppBarButton.Icon></AppBarButton><AppBarButton x:Uid="SessionsDuplicateCommand" Click="OnDuplicateClicked" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"><AppBarButton.Icon><SymbolIcon Symbol="Save" /></AppBarButton.Icon></AppBarButton><AppBarButton x:Uid="SessionsArchiveCommand" Click="OnArchiveClicked" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"><AppBarButton.Icon><SymbolIcon Symbol="Delete" /></AppBarButton.Icon></AppBarButton><AppBarButton x:Uid="SessionsExportCommand" Click="OnExportClicked"><AppBarButton.Icon><SymbolIcon Symbol="Save" /></AppBarButton.Icon></AppBarButton><AppBarButton x:Uid="SessionsImportCommand" Click="OnImportClicked"><AppBarButton.Icon><SymbolIcon Symbol="OpenFile" /></AppBarButton.Icon></AppBarButton><CommandBar.SecondaryCommands><AppBarButton x:Uid="SessionsDeleteCommand" Click="OnDeleteClicked" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}"><AppBarButton.Icon><SymbolIcon Symbol="Delete" /></AppBarButton.Icon></AppBarButton><AppBarButton x:Uid="SessionsRefreshCommand" Click="OnRefreshClicked"><AppBarButton.Icon><SymbolIcon Symbol="Refresh" /></AppBarButton.Icon></AppBarButton></CommandBar.SecondaryCommands></CommandBar></Grid>
        <InfoBar x:Uid="SessionsStatusInfoBar" Grid.Row="2" IsClosable="False" IsOpen="{x:Bind ViewModel.HasStatusMessage, Mode=OneWay}" Message="{x:Bind ViewModel.StatusDetails, Mode=OneWay}" Severity="{x:Bind ViewModel.StatusSeverity, Mode=OneWay}" Title="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
         <Grid Grid.Row="3" ColumnSpacing="{StaticResource AstralContentSpacing}"><Grid.ColumnDefinitions><ColumnDefinition Width="300" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Border Style="{StaticResource AstralCardBorderStyle}"><ListView x:Name="SessionList" AutomationProperties.AutomationId="SessionsList" ItemsSource="{x:Bind ViewModel.Sessions, Mode=OneWay}" SelectedIndex="{x:Bind ViewModel.SelectedIndex, Mode=TwoWay}"><ListView.ItemTemplate><DataTemplate><TextBlock Padding="8" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{Binding}" TextTrimming="CharacterEllipsis" /></DataTemplate></ListView.ItemTemplate></ListView></Border><ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"><StackPanel Spacing="{StaticResource AstralContentSpacing}"><Border Style="{StaticResource AstralCardBorderStyle}"><StackPanel Spacing="{StaticResource AstralContentSpacing}"><TextBlock x:Uid="SessionsEditorTitle" Style="{StaticResource AstralSectionHeaderTextBlockStyle}" /><TextBox x:Uid="SessionsNameBox" Text="{x:Bind ViewModel.SelectedName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /><TextBox x:Uid="SessionsDescriptionBox" Text="{x:Bind ViewModel.EditorDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" /><ComboBox x:Uid="SessionsChannelsBox" AutomationProperties.AutomationId="SessionsChannelsBox" SelectedValue="{x:Bind ViewModel.EditorChannels, Mode=OneWay}" SelectedValuePath="Tag" SelectionChanged="OnChannelsChanged"><ComboBoxItem x:Uid="EventLogsSystemNavigationItem" Tag="System" /><ComboBoxItem x:Uid="EventLogsApplicationNavigationItem" Tag="Application" /><ComboBoxItem x:Uid="EventLogsSecurityNavigationItem" Tag="Security" /><ComboBoxItem x:Uid="EventLogsSetupNavigationItem" Tag="Setup" /><ComboBoxItem x:Uid="EventLogsForwardedEventsNavigationItem" Tag="ForwardedEvents" /></ComboBox><TextBox x:Uid="SessionsFilterBox" Text="{x:Bind ViewModel.EditorFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" /><TextBox x:Uid="SessionsRemoteTargetBox" Text="{x:Bind ViewModel.EditorRemoteTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /><CheckBox x:Uid="SessionsPinnedCheckBox" IsChecked="{x:Bind ViewModel.EditorPinned, Mode=TwoWay}" /></StackPanel></Border><Border Style="{StaticResource AstralCardBorderStyle}"><StackPanel Spacing="{StaticResource AstralContentSpacing}"><TextBlock x:Uid="SessionsMetadataTitle" Style="{StaticResource AstralSectionHeaderTextBlockStyle}" /><TextBox x:Uid="SessionsStartAtBox" Text="{x:Bind ViewModel.EditorStartAt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /><TextBox x:Uid="SessionsEndAtBox" Text="{x:Bind ViewModel.EditorEndAt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /><TextBox x:Uid="SessionsBookmarkedEventIdsBox" Text="{x:Bind ViewModel.EditorBookmarkedEventIds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" /><TextBox x:Uid="SessionsTagsBox" Text="{x:Bind ViewModel.EditorTags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /><TextBox x:Uid="SessionsCorrelationBox" Text="{x:Bind ViewModel.EditorCorrelationGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /><TextBox x:Uid="SessionsNotesBox" Text="{x:Bind ViewModel.EditorNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" /><CheckBox x:Uid="SessionsArchivedCheckBox" IsChecked="{x:Bind ViewModel.EditorArchived, Mode=OneWay}" IsEnabled="False" /><TextBlock AutomationProperties.AutomationId="SessionsActiveSummary" Style="{StaticResource AstralCaptionTextBlockStyle}" Text="{x:Bind ViewModel.ActiveSummary, Mode=OneWay}" TextWrapping="Wrap" /></StackPanel></Border></StackPanel></ScrollViewer></Grid>
    </Grid>
</Page>
