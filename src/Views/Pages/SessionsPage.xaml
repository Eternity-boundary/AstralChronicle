<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AstralChronicle.SessionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid
        x:Name="PageRoot"
        RowSpacing="{StaticResource AstralContentSpacing}"
        Style="{StaticResource AstralPageGridStyle}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="SessionsLayoutStates">
                <VisualState x:Name="SessionsNarrowLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SessionsMasterColumn.Width" Value="*" />
                        <Setter Target="SessionsEditorColumn.Width" Value="0" />
                        <Setter Target="SessionsPrimaryRow.Height" Value="2*" />
                        <Setter Target="SessionsSecondaryRow.Height" Value="3*" />
                        <Setter Target="SessionsContentGrid.RowSpacing" Value="{StaticResource AstralContentSpacing}" />
                        <Setter Target="SessionsMasterPane.(Grid.Column)" Value="0" />
                        <Setter Target="SessionsMasterPane.(Grid.Row)" Value="0" />
                        <Setter Target="SessionsEditorPane.(Grid.Column)" Value="0" />
                        <Setter Target="SessionsEditorPane.(Grid.Row)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="SessionsWideLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="900" />
                    </VisualState.StateTriggers>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="{StaticResource AstralContentSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                <TextBlock
                    x:Uid="SessionsHeading"
                    AutomationProperties.AutomationId="SessionsHeading"
                    Style="{StaticResource AstralPageTitleTextBlockStyle}" />
                <TextBlock
                    AutomationProperties.AutomationId="SessionsSummary"
                    Style="{StaticResource AstralBodyTextBlockStyle}"
                    Text="{x:Bind ViewModel.Summary, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </StackPanel>
            <CommandBar
                x:Name="SessionsCommandBar"
                Grid.Column="1"
                AutomationProperties.AutomationId="SessionsCommandBar"
                DefaultLabelPosition="Right">
                <AppBarButton x:Uid="SessionsNewCommand" AutomationProperties.AutomationId="SessionsNewCommand" Click="OnNewClicked">
                    <AppBarButton.Icon><SymbolIcon Symbol="Add" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Uid="SessionsSaveCommand" AutomationProperties.AutomationId="SessionsSaveCommand" Click="OnSaveClicked" IsEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}">
                    <AppBarButton.Icon><SymbolIcon Symbol="Save" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Uid="SessionsResumeCommand" AutomationProperties.AutomationId="SessionsResumeCommand" Click="OnResumeClicked" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}">
                    <AppBarButton.Icon><SymbolIcon Symbol="Play" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Uid="SessionsPinCommand" AutomationProperties.AutomationId="SessionsPinCommand" Click="OnPinClicked" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}">
                    <AppBarButton.Icon><SymbolIcon Symbol="Favorite" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Uid="SessionsDuplicateCommand" AutomationProperties.AutomationId="SessionsDuplicateCommand" Click="OnDuplicateClicked" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}">
                    <AppBarButton.Icon><SymbolIcon Symbol="Save" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Uid="SessionsArchiveCommand" AutomationProperties.AutomationId="SessionsArchiveCommand" Click="OnArchiveClicked" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}">
                    <AppBarButton.Icon><SymbolIcon Symbol="Delete" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Uid="SessionsExportCommand" AutomationProperties.AutomationId="SessionsExportCommand" Click="OnExportClicked">
                    <AppBarButton.Icon><SymbolIcon Symbol="Save" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Uid="SessionsImportCommand" AutomationProperties.AutomationId="SessionsImportCommand" Click="OnImportClicked">
                    <AppBarButton.Icon><SymbolIcon Symbol="OpenFile" /></AppBarButton.Icon>
                </AppBarButton>
                <CommandBar.SecondaryCommands>
                    <AppBarButton x:Uid="SessionsDeleteCommand" AutomationProperties.AutomationId="SessionsDeleteCommand" Click="OnDeleteClicked" IsEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}">
                        <AppBarButton.Icon><SymbolIcon Symbol="Delete" /></AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Uid="SessionsRefreshCommand" AutomationProperties.AutomationId="SessionsRefreshCommand" Click="OnRefreshClicked">
                        <AppBarButton.Icon><SymbolIcon Symbol="Refresh" /></AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar.SecondaryCommands>
            </CommandBar>
        </Grid>

        <InfoBar
            x:Name="SessionsStatusInfoBar"
            x:Uid="SessionsStatusInfoBar"
            Grid.Row="1"
            AutomationProperties.AutomationId="SessionsStatusInfoBar"
            IsClosable="False"
            IsOpen="{x:Bind ViewModel.HasStatusMessage, Mode=OneWay}"
            Message="{x:Bind ViewModel.StatusDetails, Mode=OneWay}"
            Severity="{x:Bind ViewModel.StatusSeverity, Mode=OneWay}"
            Title="{x:Bind ViewModel.StatusText, Mode=OneWay}" />

        <Grid
            x:Name="SessionsContentGrid"
            Grid.Row="2"
            ColumnSpacing="{StaticResource AstralContentSpacing}"
            RowSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SessionsMasterColumn" Width="300" />
                <ColumnDefinition x:Name="SessionsEditorColumn" Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="SessionsPrimaryRow" Height="*" />
                <RowDefinition x:Name="SessionsSecondaryRow" Height="0" />
            </Grid.RowDefinitions>
            <Border
                x:Name="SessionsMasterPane"
                Grid.Row="0"
                Grid.Column="0"
                Style="{StaticResource AstralCardBorderStyle}">
                <ListView
                    x:Name="SessionList"
                    AutomationProperties.AutomationId="SessionsList"
                    ItemsSource="{x:Bind ViewModel.Sessions, Mode=OneWay}"
                    SelectedIndex="{x:Bind ViewModel.SelectedIndex, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock
                                Padding="8"
                                Style="{StaticResource AstralBodyTextBlockStyle}"
                                Text="{x:Bind Mode=OneTime}"
                                TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
            <ScrollViewer
                x:Name="SessionsEditorPane"
                Grid.Row="0"
                Grid.Column="1"
                AutomationProperties.AutomationId="SessionsEditorScrollViewer"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                    <Border Style="{StaticResource AstralCardBorderStyle}">
                        <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                            <TextBlock x:Uid="SessionsEditorTitle" Style="{StaticResource AstralSectionHeaderTextBlockStyle}" />
                            <TextBox x:Uid="SessionsNameBox" AutomationProperties.AutomationId="SessionsNameBox" Text="{x:Bind ViewModel.SelectedName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox x:Uid="SessionsDescriptionBox" AutomationProperties.AutomationId="SessionsDescriptionBox" AcceptsReturn="True" Text="{x:Bind ViewModel.EditorDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                            <ComboBox x:Uid="SessionsChannelsBox" AutomationProperties.AutomationId="SessionsChannelsBox" SelectedValue="{x:Bind ViewModel.EditorChannels, Mode=OneWay}" SelectedValuePath="Tag" SelectionChanged="OnChannelsChanged">
                                <ComboBoxItem x:Uid="EventLogsSystemNavigationItem" Tag="System" />
                                <ComboBoxItem x:Uid="EventLogsApplicationNavigationItem" Tag="Application" />
                                <ComboBoxItem x:Uid="EventLogsSecurityNavigationItem" Tag="Security" />
                                <ComboBoxItem x:Uid="EventLogsSetupNavigationItem" Tag="Setup" />
                                <ComboBoxItem x:Uid="EventLogsForwardedEventsNavigationItem" Tag="ForwardedEvents" />
                            </ComboBox>
                            <TextBox x:Uid="SessionsFilterBox" AutomationProperties.AutomationId="SessionsFilterBox" AcceptsReturn="True" Text="{x:Bind ViewModel.EditorFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                            <TextBox x:Uid="SessionsRemoteTargetBox" AutomationProperties.AutomationId="SessionsRemoteTargetBox" Text="{x:Bind ViewModel.EditorRemoteTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox x:Uid="SessionsPinnedCheckBox" AutomationProperties.AutomationId="SessionsPinnedCheckBox" IsChecked="{x:Bind ViewModel.EditorPinned, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource AstralCardBorderStyle}">
                        <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                            <TextBlock x:Uid="SessionsMetadataTitle" Style="{StaticResource AstralSectionHeaderTextBlockStyle}" />
                            <TextBox x:Uid="SessionsStartAtBox" AutomationProperties.AutomationId="SessionsStartAtBox" Text="{x:Bind ViewModel.EditorStartAt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox x:Uid="SessionsEndAtBox" AutomationProperties.AutomationId="SessionsEndAtBox" Text="{x:Bind ViewModel.EditorEndAt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox x:Uid="SessionsBookmarkedEventIdsBox" AutomationProperties.AutomationId="SessionsBookmarkedEventIdsBox" Text="{x:Bind ViewModel.EditorBookmarkedEventIds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                            <TextBox x:Uid="SessionsTagsBox" AutomationProperties.AutomationId="SessionsTagsBox" Text="{x:Bind ViewModel.EditorTags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox x:Uid="SessionsCorrelationBox" AutomationProperties.AutomationId="SessionsCorrelationBox" Text="{x:Bind ViewModel.EditorCorrelationGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox x:Uid="SessionsNotesBox" AutomationProperties.AutomationId="SessionsNotesBox" AcceptsReturn="True" Text="{x:Bind ViewModel.EditorNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                            <CheckBox x:Uid="SessionsArchivedCheckBox" AutomationProperties.AutomationId="SessionsArchivedCheckBox" IsChecked="{x:Bind ViewModel.EditorArchived, Mode=OneWay}" IsEnabled="False" />
                            <TextBlock AutomationProperties.AutomationId="SessionsActiveSummary" Style="{StaticResource AstralCaptionTextBlockStyle}" Text="{x:Bind ViewModel.ActiveSummary, Mode=OneWay}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
