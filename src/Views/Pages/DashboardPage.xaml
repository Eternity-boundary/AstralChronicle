<Page
    x:Class="AstralChronicle.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AstralChronicle">

    <ScrollViewer x:Name="PageRoot" Style="{StaticResource AstralPageScrollViewerStyle}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="DashboardMetricLayoutStates">
                <VisualState x:Name="DashboardMetricNarrowLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="DashboardMetricColumn0.Width" Value="*" />
                        <Setter Target="DashboardMetricColumn1.Width" Value="0" />
                        <Setter Target="DashboardMetricColumn2.Width" Value="0" />
                        <Setter Target="DashboardMetricColumn3.Width" Value="0" />
                        <Setter Target="DashboardMetricRow0.Height" Value="Auto" />
                        <Setter Target="DashboardMetricRow1.Height" Value="Auto" />
                        <Setter Target="DashboardMetricRow2.Height" Value="Auto" />
                        <Setter Target="DashboardMetricRow3.Height" Value="Auto" />
                        <Setter Target="DashboardMetricGrid.ColumnSpacing" Value="0" />
                        <Setter Target="DashboardErrorNavigationCard.(Grid.Column)" Value="0" />
                        <Setter Target="DashboardErrorNavigationCard.(Grid.Row)" Value="0" />
                        <Setter Target="DashboardWarningNavigationCard.(Grid.Column)" Value="0" />
                        <Setter Target="DashboardWarningNavigationCard.(Grid.Row)" Value="1" />
                        <Setter Target="DashboardWarningNavigationCard.Margin" Value="0,8,0,0" />
                        <Setter Target="DashboardCriticalNavigationCard.(Grid.Column)" Value="0" />
                        <Setter Target="DashboardCriticalNavigationCard.(Grid.Row)" Value="2" />
                        <Setter Target="DashboardCriticalNavigationCard.Margin" Value="0,8,0,0" />
                        <Setter Target="DashboardServiceStatusCard.(Grid.Column)" Value="0" />
                        <Setter Target="DashboardServiceStatusCard.(Grid.Row)" Value="3" />
                        <Setter Target="DashboardServiceStatusCard.Margin" Value="0,8,0,0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="DashboardMetricMediumLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="720" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="DashboardMetricColumn0.Width" Value="*" />
                        <Setter Target="DashboardMetricColumn1.Width" Value="*" />
                        <Setter Target="DashboardMetricColumn2.Width" Value="0" />
                        <Setter Target="DashboardMetricColumn3.Width" Value="0" />
                        <Setter Target="DashboardMetricRow0.Height" Value="Auto" />
                        <Setter Target="DashboardMetricRow1.Height" Value="Auto" />
                        <Setter Target="DashboardMetricRow2.Height" Value="0" />
                        <Setter Target="DashboardMetricRow3.Height" Value="0" />
                        <Setter Target="DashboardErrorNavigationCard.(Grid.Column)" Value="0" />
                        <Setter Target="DashboardErrorNavigationCard.(Grid.Row)" Value="0" />
                        <Setter Target="DashboardWarningNavigationCard.(Grid.Column)" Value="1" />
                        <Setter Target="DashboardWarningNavigationCard.(Grid.Row)" Value="0" />
                        <Setter Target="DashboardCriticalNavigationCard.(Grid.Column)" Value="0" />
                        <Setter Target="DashboardCriticalNavigationCard.(Grid.Row)" Value="1" />
                        <Setter Target="DashboardCriticalNavigationCard.Margin" Value="0,8,0,0" />
                        <Setter Target="DashboardServiceStatusCard.(Grid.Column)" Value="1" />
                        <Setter Target="DashboardServiceStatusCard.(Grid.Row)" Value="1" />
                        <Setter Target="DashboardServiceStatusCard.Margin" Value="0,8,0,0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="DashboardMetricWideLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1200" />
                    </VisualState.StateTriggers>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <StackPanel MaxWidth="{StaticResource AstralPageContentMaxWidth}" Spacing="{StaticResource AstralSectionSpacing}">
            <TextBlock
                AutomationProperties.AutomationId="DashboardHeading"
                Style="{StaticResource AstralPageTitleTextBlockStyle}"
                Text="{x:Bind ViewModel.Heading, Mode=OneWay}" />

            <Grid ColumnSpacing="{StaticResource AstralContentSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    AutomationProperties.AutomationId="DashboardSummary"
                    Style="{StaticResource AstralBodyTextBlockStyle}"
                    Text="{x:Bind ViewModel.Summary, Mode=OneWay}"
                    TextWrapping="Wrap" />
                <ProgressRing
                    x:Name="DashboardLoadingIndicator"
                    Grid.Column="1"
                    AutomationProperties.AutomationId="DashboardLoadingIndicator"
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    IsIndeterminate="True"
                    Width="24"
                    Height="24" />
            </Grid>

            <InfoBar
                x:Uid="DashboardStatusInfoBar"
                AutomationProperties.AutomationId="DashboardStatusInfoBar"
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.HasStatusMessage, Mode=OneWay}"
                Message="{x:Bind ViewModel.StatusDetails, Mode=OneWay}"
                Severity="{x:Bind ViewModel.StatusSeverity, Mode=OneWay}"
                Title="{x:Bind ViewModel.StatusText, Mode=OneWay}" />

            <Grid
                x:Name="DashboardMetricGrid"
                ColumnSpacing="{StaticResource AstralContentSpacing}"
                RowSpacing="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="DashboardMetricColumn0" Width="*" />
                    <ColumnDefinition x:Name="DashboardMetricColumn1" Width="*" />
                    <ColumnDefinition x:Name="DashboardMetricColumn2" Width="*" />
                    <ColumnDefinition x:Name="DashboardMetricColumn3" Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="DashboardMetricRow0" Height="Auto" />
                    <RowDefinition x:Name="DashboardMetricRow1" Height="0" />
                    <RowDefinition x:Name="DashboardMetricRow2" Height="0" />
                    <RowDefinition x:Name="DashboardMetricRow3" Height="0" />
                </Grid.RowDefinitions>

                <ContentControl
                    x:Name="DashboardErrorNavigationCard"
                    x:Uid="DashboardErrorNavigationCard"
                    Grid.Column="0"
                    AutomationProperties.AutomationId="DashboardErrorNavigationCard"
                    AutomationProperties.ItemStatus="{x:Bind ViewModel.ErrorCount, Mode=OneWay}"
                    AutomationProperties.LabeledBy="{x:Bind DashboardErrorCardTitle, Mode=OneTime}"
                    HorizontalContentAlignment="Stretch"
                    IsTabStop="True"
                    IsTapEnabled="True"
                    KeyDown="OnNavigationCardKeyDown"
                    MinHeight="128"
                    Padding="0"
                    Tapped="OnNavigationCardTapped"
                    UseSystemFocusVisuals="True"
                    VerticalContentAlignment="Stretch">
                    <Border
                        MinHeight="128"
                        Padding="{StaticResource AstralCardPadding}"
                        Style="{StaticResource AstralCardBorderStyle}">
                        <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                            <TextBlock
                                x:Name="DashboardErrorCardTitle"
                                x:Uid="DashboardErrorCardTitle"
                                AutomationProperties.AutomationId="DashboardErrorCardTitle"
                                Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                            <TextBlock
                                AutomationProperties.AutomationId="DashboardErrorCount"
                                Style="{StaticResource AstralPageTitleTextBlockStyle}"
                                Text="{x:Bind ViewModel.ErrorCount, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </ContentControl>

                <ContentControl
                    x:Name="DashboardWarningNavigationCard"
                    x:Uid="DashboardWarningNavigationCard"
                    Grid.Column="1"
                    AutomationProperties.AutomationId="DashboardWarningNavigationCard"
                    AutomationProperties.ItemStatus="{x:Bind ViewModel.WarningCount, Mode=OneWay}"
                    AutomationProperties.LabeledBy="{x:Bind DashboardWarningCardTitle, Mode=OneTime}"
                    HorizontalContentAlignment="Stretch"
                    IsTabStop="True"
                    IsTapEnabled="True"
                    KeyDown="OnNavigationCardKeyDown"
                    MinHeight="128"
                    Padding="0"
                    Tapped="OnNavigationCardTapped"
                    UseSystemFocusVisuals="True"
                    VerticalContentAlignment="Stretch">
                    <Border
                        MinHeight="128"
                        Padding="{StaticResource AstralCardPadding}"
                        Style="{StaticResource AstralCardBorderStyle}">
                        <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                            <TextBlock
                                x:Name="DashboardWarningCardTitle"
                                x:Uid="DashboardWarnCardTitle"
                                AutomationProperties.AutomationId="DashboardWarnCardTitle"
                                Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                            <TextBlock
                                AutomationProperties.AutomationId="DashboardWarningCount"
                                Style="{StaticResource AstralPageTitleTextBlockStyle}"
                                Text="{x:Bind ViewModel.WarningCount, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </ContentControl>

                <ContentControl
                    x:Name="DashboardCriticalNavigationCard"
                    x:Uid="DashboardCriticalNavigationCard"
                    Grid.Column="2"
                    AutomationProperties.AutomationId="DashboardCriticalNavigationCard"
                    AutomationProperties.ItemStatus="{x:Bind ViewModel.CriticalCount, Mode=OneWay}"
                    AutomationProperties.LabeledBy="{x:Bind DashboardCriticalCardTitle, Mode=OneTime}"
                    HorizontalContentAlignment="Stretch"
                    IsTabStop="True"
                    IsTapEnabled="True"
                    KeyDown="OnNavigationCardKeyDown"
                    MinHeight="128"
                    Padding="0"
                    Tapped="OnNavigationCardTapped"
                    UseSystemFocusVisuals="True"
                    VerticalContentAlignment="Stretch">
                    <Border
                        MinHeight="128"
                        Padding="{StaticResource AstralCardPadding}"
                        Style="{StaticResource AstralCardBorderStyle}">
                        <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                            <TextBlock
                                x:Name="DashboardCriticalCardTitle"
                                x:Uid="DashboardTodayCardTitle"
                                AutomationProperties.AutomationId="DashboardTodayCardTitle"
                                Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                            <TextBlock
                                AutomationProperties.AutomationId="DashboardCriticalCount"
                                Style="{StaticResource AstralPageTitleTextBlockStyle}"
                                Text="{x:Bind ViewModel.CriticalCount, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </ContentControl>

                <Border
                    x:Name="DashboardServiceStatusCard"
                    Grid.Column="3"
                    MinHeight="128"
                    Padding="{StaticResource AstralCardPadding}"
                    Style="{StaticResource AstralCardBorderStyle}">
                    <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                        <TextBlock
                            x:Uid="DashboardServiceStatusCardTitle"
                            AutomationProperties.AutomationId="DashboardServiceStatusCardTitle"
                            Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                        <Grid ColumnSpacing="{StaticResource AstralContentSpacing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Ellipse
                                Width="10"
                                Height="10"
                                VerticalAlignment="Center"
                                Fill="{ThemeResource SystemFillColorCautionBrush}"
                                IsHitTestVisible="False" />
                            <TextBlock
                                x:Uid="DashboardServiceStatusMonitoringNotConfigured"
                                Grid.Column="1"
                                AutomationProperties.AutomationId="DashboardServiceStatusText"
                                Style="{StaticResource AstralCaptionTextBlockStyle}"
                                Text="{x:Bind ViewModel.MonitoringStatus, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </Grid>
                        <TextBlock x:Uid="DashboardTodayTotalLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                        <TextBlock AutomationProperties.AutomationId="DashboardTodayCount" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.TodayCount, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid
                ColumnSpacing="{StaticResource AstralContentSpacing}"
                RowSpacing="{StaticResource AstralContentSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="{StaticResource AstralContentSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Uid="DashboardRecentCriticalEventsTitle"
                        AutomationProperties.AutomationId="DashboardRecentCriticalEventsTitle"
                        Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                    <HyperlinkButton
                        x:Uid="DashboardViewAllEventsButton"
                        Grid.Column="1"
                        AutomationProperties.AutomationId="DashboardViewAllEventsButton"
                        Click="OnViewAllEventsClicked"
                        Style="{StaticResource DefaultHyperlinkButtonStyle}" />
                </Grid>

                <TextBlock
                    x:Uid="DashboardCrashTimelineTitle"
                    Grid.Row="0"
                    Grid.Column="1"
                    AutomationProperties.AutomationId="DashboardCrashTimelineTitle"
                    Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />

                <Border Grid.Row="1" MinHeight="280" Style="{StaticResource AstralCardBorderStyle}">
                    <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                        <TextBlock
                            AutomationProperties.AutomationId="DashboardRecentCriticalEventPreview"
                            Style="{StaticResource AstralCaptionTextBlockStyle}"
                            Text="{x:Bind ViewModel.RecentEventPreview, Mode=OneWay}"
                            TextWrapping="Wrap" />
                        <ListView
                            AutomationProperties.AutomationId="DashboardRecentCriticalEventsList"
                            ItemsSource="{x:Bind ViewModel.RecentCriticalEvents, Mode=OneWay}"
                            IsItemClickEnabled="False"
                            MaxHeight="220"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:EventLogItemViewModel">
                                    <Grid ColumnSpacing="{StaticResource AstralContentSpacing}" MinHeight="48">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Style="{StaticResource AstralCaptionTextBlockStyle}"
                                            Text="{x:Bind Level, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Style="{StaticResource AstralCaptionTextBlockStyle}"
                                            Text="{x:Bind TimeCreated, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                        <StackPanel Grid.Column="2" Spacing="{StaticResource AstralContentSpacing}">
                                            <TextBlock
                                                Style="{StaticResource AstralBodyTextBlockStyle}"
                                                Text="{x:Bind Provider, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Style="{StaticResource AstralCaptionTextBlockStyle}"
                                                Text="{x:Bind ShortDescription, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock
                                            Grid.Column="3"
                                            MaxWidth="140"
                                            Style="{StaticResource AstralCaptionTextBlockStyle}"
                                            Text="{x:Bind Channel, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Column="4"
                                            Style="{StaticResource AstralCaptionTextBlockStyle}"
                                            Text="{x:Bind EventId, Mode=OneWay}" />
                                        <HyperlinkButton
                                            x:Uid="DashboardOpenEventButton"
                                            Grid.Column="5"
                                            AutomationProperties.AutomationId="DashboardOpenEventButton"
                                            Click="OnRecentEventClicked"
                                            Style="{StaticResource DefaultHyperlinkButtonStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    MinHeight="280"
                    Style="{StaticResource AstralCardBorderStyle}">
                    <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                    <TextBlock
                        AutomationProperties.AutomationId="DashboardCrashTimelineSummary"
                        Style="{StaticResource AstralCaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.TimelineSummary, Mode=OneWay}"
                        TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
