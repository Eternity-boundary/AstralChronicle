<Page
    x:Class="AstralChronicle.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AstralChronicle">

    <ScrollViewer x:Name="PageRoot" Style="{StaticResource AstralPageScrollViewerStyle}">
        <StackPanel MaxWidth="{StaticResource AstralPageContentMaxWidth}" Spacing="{StaticResource AstralSectionSpacing}">
            <TextBlock
                AutomationProperties.AutomationId="DashboardHeading"
                Style="{StaticResource AstralPageTitleTextBlockStyle}"
                Text="{x:Bind ViewModel.Heading, Mode=OneWay}" />

            <Grid ColumnSpacing="{StaticResource AstralContentSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    AutomationProperties.AutomationId="DashboardSummary"
                    Style="{StaticResource AstralBodyTextBlockStyle}"
                    Text="{x:Bind ViewModel.Summary, Mode=OneWay}"
                    TextWrapping="Wrap" />
                <ProgressRing
                    Grid.Column="1"
                    AutomationProperties.AutomationId="DashboardLoadingIndicator"
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    IsIndeterminate="True"
                    Width="24"
                    Height="24" />
            </Grid>

            <InfoBar
                x:Uid="DashboardStatusInfoBar"
                AutomationProperties.AutomationId="DashboardStatusInfoBar"
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.HasStatusMessage, Mode=OneWay}"
                Message="{x:Bind ViewModel.StatusDetails, Mode=OneWay}"
                Severity="{x:Bind ViewModel.StatusSeverity, Mode=OneWay}"
                Title="{x:Bind ViewModel.StatusText, Mode=OneWay}" />

            <Grid ColumnSpacing="{StaticResource AstralContentSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    IsTapEnabled="True"
                    MinHeight="128"
                    Padding="{StaticResource AstralCardPadding}"
                    Style="{StaticResource AstralCardBorderStyle}"
                    Tapped="OnErrorCardTapped">
                    <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                        <TextBlock
                            x:Uid="DashboardErrorCardTitle"
                            AutomationProperties.AutomationId="DashboardErrorCardTitle"
                            Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                        <TextBlock
                            AutomationProperties.AutomationId="DashboardErrorCount"
                            Style="{StaticResource AstralPageTitleTextBlockStyle}"
                            Text="{x:Bind ViewModel.ErrorCount, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    IsTapEnabled="True"
                    MinHeight="128"
                    Padding="{StaticResource AstralCardPadding}"
                    Style="{StaticResource AstralCardBorderStyle}"
                    Tapped="OnWarningCardTapped">
                    <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                        <TextBlock
                            x:Uid="DashboardWarnCardTitle"
                            AutomationProperties.AutomationId="DashboardWarnCardTitle"
                            Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                        <TextBlock
                            AutomationProperties.AutomationId="DashboardWarningCount"
                            Style="{StaticResource AstralPageTitleTextBlockStyle}"
                            Text="{x:Bind ViewModel.WarningCount, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    IsTapEnabled="True"
                    MinHeight="128"
                    Padding="{StaticResource AstralCardPadding}"
                    Style="{StaticResource AstralCardBorderStyle}"
                    Tapped="OnCriticalCardTapped">
                    <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                        <TextBlock
                            x:Uid="DashboardTodayCardTitle"
                            AutomationProperties.AutomationId="DashboardTodayCardTitle"
                            Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                        <TextBlock
                            AutomationProperties.AutomationId="DashboardCriticalCount"
                            Style="{StaticResource AstralPageTitleTextBlockStyle}"
                            Text="{x:Bind ViewModel.CriticalCount, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="3"
                    MinHeight="128"
                    Padding="{StaticResource AstralCardPadding}"
                    Style="{StaticResource AstralCardBorderStyle}">
                    <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                        <TextBlock
                            x:Uid="DashboardServiceStatusCardTitle"
                            AutomationProperties.AutomationId="DashboardServiceStatusCardTitle"
                            Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource AstralContentSpacing}">
                            <Ellipse
                                Width="10"
                                Height="10"
                                VerticalAlignment="Center"
                                Fill="{ThemeResource SystemFillColorCautionBrush}"
                                IsHitTestVisible="False" />
                            <TextBlock
                                x:Uid="DashboardServiceStatusMonitoringNotConfigured"
                                AutomationProperties.AutomationId="DashboardServiceStatusText"
                                Style="{StaticResource AstralCaptionTextBlockStyle}"
                                Text="{x:Bind ViewModel.MonitoringStatus, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBlock x:Uid="DashboardTodayTotalLabel" Style="{StaticResource AstralCaptionTextBlockStyle}" />
                        <TextBlock AutomationProperties.AutomationId="DashboardTodayCount" Style="{StaticResource AstralBodyTextBlockStyle}" Text="{x:Bind ViewModel.TodayCount, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="{StaticResource AstralContentSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                    <Grid ColumnSpacing="{StaticResource AstralContentSpacing}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Uid="DashboardRecentCriticalEventsTitle"
                            AutomationProperties.AutomationId="DashboardRecentCriticalEventsTitle"
                            Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                        <HyperlinkButton
                            x:Uid="DashboardViewAllEventsButton"
                            Grid.Column="1"
                            AutomationProperties.AutomationId="DashboardViewAllEventsButton"
                            Click="OnViewAllEventsClicked"
                            Style="{StaticResource DefaultHyperlinkButtonStyle}" />
                    </Grid>
                    <Border MinHeight="280" Style="{StaticResource AstralCardBorderStyle}">
                        <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                            <TextBlock
                                AutomationProperties.AutomationId="DashboardRecentCriticalEventPreview"
                                Style="{StaticResource AstralCaptionTextBlockStyle}"
                                Text="{x:Bind ViewModel.RecentEventPreview, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <ListView
                                AutomationProperties.AutomationId="DashboardRecentCriticalEventsList"
                                ItemsSource="{x:Bind ViewModel.RecentCriticalEvents, Mode=OneWay}"
                                IsItemClickEnabled="False"
                                MaxHeight="220"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:EventLogItemViewModel">
                                        <Grid ColumnSpacing="{StaticResource AstralContentSpacing}" MinHeight="48">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Style="{StaticResource AstralCaptionTextBlockStyle}"
                                                Text="{x:Bind Level, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Style="{StaticResource AstralCaptionTextBlockStyle}"
                                                Text="{x:Bind TimeCreated, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <StackPanel Grid.Column="2" Spacing="{StaticResource AstralContentSpacing}">
                                                <TextBlock
                                                    Style="{StaticResource AstralBodyTextBlockStyle}"
                                                    Text="{x:Bind Provider, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Style="{StaticResource AstralCaptionTextBlockStyle}"
                                                    Text="{x:Bind ShortDescription, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock
                                                Grid.Column="3"
                                                MaxWidth="140"
                                                Style="{StaticResource AstralCaptionTextBlockStyle}"
                                                Text="{x:Bind Channel, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="4"
                                                Style="{StaticResource AstralCaptionTextBlockStyle}"
                                                Text="{x:Bind EventId, Mode=OneWay}" />
                                            <HyperlinkButton
                                                x:Uid="DashboardOpenEventButton"
                                                Grid.Column="5"
                                                AutomationProperties.AutomationId="DashboardOpenEventButton"
                                                Click="OnRecentEventClicked"
                                                DataContext="{x:Bind}"
                                                Style="{StaticResource DefaultHyperlinkButtonStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="{StaticResource AstralContentSpacing}">
                    <TextBlock
                        x:Uid="DashboardCrashTimelineTitle"
                        AutomationProperties.AutomationId="DashboardCrashTimelineTitle"
                        Style="{StaticResource AstralPageSubtitleTextBlockStyle}" />
                    <Border MinHeight="280" Style="{StaticResource AstralCardBorderStyle}">
                        <StackPanel Spacing="{StaticResource AstralContentSpacing}">
                            <TextBlock
                                AutomationProperties.AutomationId="DashboardCrashTimelineSummary"
                                Style="{StaticResource AstralCaptionTextBlockStyle}"
                                Text="{x:Bind ViewModel.TimelineSummary, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
