<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style
        x:Key="AstralPageTitleTextBlockStyle"
        BasedOn="{StaticResource TitleTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource AstralPrimaryTextBrush}" />
    </Style>

    <Style
        x:Key="AstralPageSubtitleTextBlockStyle"
        BasedOn="{StaticResource SubtitleTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource AstralPrimaryTextBrush}" />
    </Style>

    <Style
        x:Key="AstralSectionHeaderTextBlockStyle"
        BasedOn="{StaticResource SubtitleTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource AstralPrimaryTextBrush}" />
    </Style>

    <Style
        x:Key="AstralBodyTextBlockStyle"
        BasedOn="{StaticResource BodyTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource AstralPrimaryTextBrush}" />
    </Style>

    <Style
        x:Key="AstralCaptionTextBlockStyle"
        BasedOn="{StaticResource CaptionTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource AstralSecondaryTextBrush}" />
    </Style>

    <Style x:Key="AstralPageScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="Padding" Value="32" />
    </Style>

    <Style x:Key="AstralPageGridStyle" TargetType="Grid">
        <Setter Property="Padding" Value="32" />
    </Style>

    <Style x:Key="AstralCardBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="20" />
        <Setter Property="Background" Value="{ThemeResource AstralCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AstralCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
    </Style>

    <Style x:Key="AstralNavigationViewStyle" TargetType="NavigationView">
        <Setter Property="Background" Value="{ThemeResource AstralTransparentBrush}" />
    </Style>
</ResourceDictionary>
