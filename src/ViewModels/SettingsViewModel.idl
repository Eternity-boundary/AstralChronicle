namespace AstralChronicle
{
    [Microsoft.UI.Xaml.Data.Bindable]
    runtimeclass SettingsViewModel : Microsoft.UI.Xaml.Data.INotifyPropertyChanged
    {
        SettingsViewModel();
        String Heading{ get; };
        String Description{ get; };
        String ThemeHint{ get; };
        Int32 SelectedThemeIndex{ get; set; };
        Boolean DefaultSortDescending{ get; set; };
        Boolean UseUtc{ get; set; };
        Boolean GroupRepeatedEvents{ get; set; };
        Boolean DetailsPaneOpen{ get; set; };
        Boolean AnimationsEnabled{ get; set; };
        String LiveQueueLimit{ get; set; };
        String QueryBatchSize{ get; set; };
        String MaxVisibleLiveRows{ get; set; };
        Boolean PersistSessions{ get; set; };
        Boolean PersistBookmarks{ get; set; };
        Boolean CacheProviderMetadata{ get; set; };
        Boolean RedactComputerName{ get; set; };
        Boolean RedactUserNames{ get; set; };
        Boolean RawXPathMode{ get; set; };
        Boolean DebugLogging{ get; set; };
    }
}
